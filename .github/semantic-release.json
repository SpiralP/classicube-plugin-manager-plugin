{
  "branches": [
    "release",
    { "name": "main", "prerelease": "alpha" },
    { "name": "master", "prerelease": "alpha" }
  ],
  "plugins": [
    [
      "@semantic-release/commit-analyzer",
      {
        "preset": "conventionalcommits",
        "releaseRules": [
          { "breaking": true, "release": "minor" },
          { "type": "feat", "release": "patch" }
        ]
      }
    ]
  ]
}
